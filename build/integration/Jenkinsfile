pipeline {
  agent any

  options {
    buildDiscarder(logRotator(numToKeepStr: '30'))
  }

  triggers {
    cron 'H 6 * * *'
  }

  parameters {
    string(name: 'engineSource', defaultValue: 'https://jenkins.ivyteam.io/job/core_product-engine/job/security-headers/lastSuccessfulBuild/', description: 'Engine page url')
  }

  stages {
    stage('Integration') {
      steps {
        script {
          def common = load 'build/build.groovy'
          def mvnArgs = "-Dmaven.test.failure.ignore=true -Pintegration "
          common.buildIntegration(mvnArgs);
        }
      }
    }
  }
}
